@model OverviewViewModel
@{ ViewData["Title"] = "Forschung"; }
@using StargateGalacticCommand.Core.Models
@functions {
    string Cost(BuildCost c) => $"NQ {c.Naquadah}, TR {c.Trinium}, VG {c.Supplies}" + (c.Energy > 0 ? $", Energie {c.Energy}" : "") + (c.Personnel > 0 ? $", Personal {c.Personnel}" : "") + (c.Intel > 0 ? $", Intel {c.Intel}" : "");
    string Duration(int seconds) => TimeSpan.FromSeconds(seconds).ToString(@"hh\:mm\:ss");
}
@if (TempData["Message"] != null) { <div class="notice success">@TempData["Message"]</div> }
@if (TempData["Error"] != null) { <div class="notice error">@TempData["Error"]</div> }
<section class="panel"><h1>@ViewData["Title"]</h1><p>Forschung gilt benutzerweit. Du benötigst ein Forschungslabor Level 1 und kannst aktuell eine Forschung gleichzeitig ausführen.</p><table><tr><th>Spieler</th><td>@Model.User.UserName</td></tr><tr><th>Fraktion</th><td>@Model.User.Faction.Name</td></tr><tr><th>Forschungslabor</th><td>Level @Model.Base.BuildingLevels.ResearchLab</td></tr><tr><th>Fraktionsmodifier</th><td>Verteidigung @((Model.DefenseModifier - 1).ToString("P0"))</td></tr></table></section>
@{
    int militaryLevel = Model.CharacterSkills?.MilitaryLevel ?? 0;
    int scienceLevel = Model.CharacterSkills?.ScienceLevel ?? 0;
    int diplomacyLevel = Model.CharacterSkills?.DiplomacyLevel ?? 0;
    int unspentPoints = Model.CharacterSkills?.UnspentPoints ?? 0;
}
<section class="panel"><h2>Charakter-Fertigkeiten</h2><p>Pro abgeschlossener Gate-Mission gibt es einen Skillpunkt. Militär erhöht den Erfolg bei Risikoanalyse-Missionen, Wissenschaft bei Artefaktsuche-Missionen und die Forschungsgeschwindigkeit, Diplomatie bei diplomatischem Kontakt (max. Stufe @StargateGalacticCommand.Core.Services.SkillTreeService.MaxLevelPerTrack pro Baum).</p><table><tr><th>Freie Skillpunkte</th><td>@unspentPoints</td></tr><tr><th>Militär</th><td>Stufe @militaryLevel<form asp-controller="Game" asp-action="InvestSkillPoint" method="post" style="display:inline"><input type="hidden" name="track" value="Military" /><button type="submit" disabled="@(unspentPoints < 1 || militaryLevel >= StargateGalacticCommand.Core.Services.SkillTreeService.MaxLevelPerTrack)">Punkt investieren</button></form></td></tr><tr><th>Wissenschaft</th><td>Stufe @scienceLevel<form asp-controller="Game" asp-action="InvestSkillPoint" method="post" style="display:inline"><input type="hidden" name="track" value="Science" /><button type="submit" disabled="@(unspentPoints < 1 || scienceLevel >= StargateGalacticCommand.Core.Services.SkillTreeService.MaxLevelPerTrack)">Punkt investieren</button></form></td></tr><tr><th>Diplomatie</th><td>Stufe @diplomacyLevel<form asp-controller="Game" asp-action="InvestSkillPoint" method="post" style="display:inline"><input type="hidden" name="track" value="Diplomacy" /><button type="submit" disabled="@(unspentPoints < 1 || diplomacyLevel >= StargateGalacticCommand.Core.Services.SkillTreeService.MaxLevelPerTrack)">Punkt investieren</button></form></td></tr></table></section>
<section class="panel"><h2>Laufende Forschung</h2>@if (Model.ActiveResearch == null) { <p>Keine aktive Forschung.</p> } else { var research = Model.Researches.SingleOrDefault(r => r.Type == Model.ActiveResearch.ResearchType); var left = Model.ActiveResearch.CompletesAtUtc - Model.NowUtc; if (left < TimeSpan.Zero) { left = TimeSpan.Zero; } <table><tr><th>Forschung</th><td>@(research == null ? Model.ActiveResearch.ResearchType.ToString() : research.Name)</td></tr><tr><th>Ziellevel</th><td>@Model.ActiveResearch.TargetLevel</td></tr><tr><th>Fertigstellung</th><td>@Model.ActiveResearch.CompletesAtUtc.ToString("u")</td></tr><tr><th>Restzeit</th><td><span class="research-timer" data-completes="@Model.ActiveResearch.CompletesAtUtc.ToString("O")">@left.ToString(@"hh\:mm\:ss")</span></td></tr></table> }</section>
@foreach (var group in Model.Researches.GroupBy(r => r.IsFactionResearch).OrderBy(g => g.Key))
{
    <section class="panel"><h2>@(group.Key ? "Fraktionsforschung" : "Allgemeine Forschung")</h2><table><thead><tr><th>Forschung</th><th>Level</th><th>Kosten</th><th>Dauer</th><th>Voraussetzung</th><th>Aktion</th></tr></thead><tbody>@foreach (var r in group) { bool disabled = r.QueueBusy || !r.CanAfford || !r.PrerequisiteMet || !r.HasResearchLab; <tr><td>@r.Name</td><td>@r.Level</td><td>@Cost(r.Cost)</td><td>@(r.HasResearchLab ? Duration(r.ResearchSeconds) : "Labor benötigt")</td><td>@(r.PrerequisiteName ?? "—")</td><td><form asp-controller="Game" asp-action="StartResearch" method="post"><input type="hidden" name="researchType" value="@r.Type" /><button type="submit" disabled="@disabled">Forschen</button>@if (!r.HasResearchLab) { <span class="hint"> Forschungslabor fehlt</span> } else if (r.QueueBusy) { <span class="hint"> Forschung läuft</span> } else if (!r.PrerequisiteMet) { <span class="hint"> Voraussetzung fehlt</span> } else if (!r.CanAfford) { <span class="hint"> Zu wenig Ressourcen</span> }</form></td></tr> }</tbody></table></section>
}
<script>document.querySelectorAll('.research-timer').forEach(function(e){function tick(){var ms=new Date(e.dataset.completes)-new Date();if(ms<0)ms=0;var s=Math.floor(ms/1000),h=Math.floor(s/3600);s%=3600;var m=Math.floor(s/60);s%=60;e.textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');}tick();setInterval(tick,1000);});</script>
