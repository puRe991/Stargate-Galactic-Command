@model OverviewViewModel
@{ ViewData["Title"] = "Sektoren"; }
@if (TempData["Message"] != null) { <div class="notice success">@TempData["Message"]</div> }
@if (TempData["Error"] != null) { <div class="notice error">@TempData["Error"]</div> }

<div class="panel">
    <div class="card-head">
        <h2>Sektoren auf @Model.Planet.Name</h2>
        <span class="hint">@Model.Sectors.Count(s => s.PlayerBase == null) frei von @Model.Sectors.Count</span>
    </div>
    <div class="item-list">
        @foreach (var s in Model.Sectors)
        {
            var isOwnBase = s.Id == Model.Base.PlanetSectorId;
            <div class="item-row">
                <div>
                    <div class="item-title">#@s.Number &middot; @s.Name</div>
                    <div class="item-meta">@(s.IsSettlementSector ? "Siedlungssektor" : "Spezialsektor") &middot; @s.SectorType</div>
                </div>
                <span class="hint">
                    @if (isOwnBase) { <text>deine Basis</text> }
                    else if (s.PlayerBase == null) { <text>frei</text> }
                    else { <text>belegt &middot; @s.PlayerBase.Name</text> }
                </span>
            </div>
        }
    </div>
</div>
