@model OverviewViewModel
@using StargateGalacticCommand.Core.Models
@{ ViewData["Title"] = "Gate-Raum"; }
@functions {
    string MissionName(GateMissionType t) {
        switch (t) {
            case GateMissionType.Explore: return "Erkunden";
            case GateMissionType.SecureResources: return "Ressourcen sichern";
            case GateMissionType.SearchArtifact: return "Artefakt suchen";
            case GateMissionType.DiplomaticContact: return "Diplomatischer Kontakt";
            case GateMissionType.RiskAnalysis: return "Risikoanalyse";
            case GateMissionType.AnalyzeAddress: return "Adresse analysieren";
            case GateMissionType.FoundColony: return "Kolonie gründen";
            default: return t.ToString();
        }
    }
}
@if (TempData["Message"] != null) { <div class="notice success">@TempData["Message"]</div> }
@if (TempData["Error"] != null) { <div class="notice error">@TempData["Error"]</div> }
<section class="panel"><h1>Gate-Raum</h1><p>Stargates transportieren ausschließlich Personen, kleine Ausrüstung und Missionsteams. Keine Schiffe, keine Großflotten, kein PvP durch das Gate.</p><table><tr><th>Gate-Kontrollraum</th><td>Level @Model.Base.BuildingLevels.GateControlRoom</td></tr><tr><th>Gate-Adressierung</th><td>Level @Model.User.ResearchLevels.GateAddressing</td></tr></table></section>
<section class="panel"><h2>Bekannte Adressen</h2><table><thead><tr><th>Adresse</th><th>Welt</th><th>Beschreibung</th><th>Risiko</th></tr></thead><tbody>@foreach(var k in Model.KnownGateAddresses){<tr><td>@k.GateAddress.Code</td><td>@k.GateAddress.WorldName</td><td>@k.GateAddress.Description</td><td>@k.GateAddress.RiskLevel</td></tr>}</tbody></table></section>
<section class="panel"><h2>Neue Mission starten</h2><form asp-controller="Game" asp-action="StartGateMission" method="post"><label>Adresse <select name="gateAddressId">@foreach(var k in Model.KnownGateAddresses){<option value="@k.GateAddressId">@k.GateAddress.Code - @k.GateAddress.Description</option>}</select></label><label>Team <select name="missionTeamId">@foreach(var t in Model.MissionTeams){<option value="@t.Id" disabled="@(!t.IsAvailable)">@t.Name @(t.IsAvailable ? "" : "(im Einsatz)")</option>}</select></label><label>Mission <select name="missionType">@foreach(var t in Enum.GetValues(typeof(GateMissionType)).Cast<GateMissionType>()){<option value="@t">@MissionName(t)</option>}</select></label><button type="submit" disabled="@(Model.Base.BuildingLevels.GateControlRoom < 1 || Model.User.ResearchLevels.GateAddressing < 1 || !Model.MissionTeams.Any(t => t.IsAvailable) || !Model.KnownGateAddresses.Any())">Mission starten</button></form></section>
<section class="panel"><h2>Laufende Gate-Missionen</h2>@if(!Model.ActiveGateMissions.Any()){<p>Keine laufenden Gate-Missionen.</p>}else{<table><thead><tr><th>Adresse</th><th>Team</th><th>Mission</th><th>Fertigstellung</th><th>Aktion</th></tr></thead><tbody>@foreach(var m in Model.ActiveGateMissions){<tr><td>@m.GateAddress.Code</td><td>@m.MissionTeam.Name</td><td>@MissionName(m.MissionType)</td><td>@m.CompletesAtUtc.ToString("u")</td><td><form asp-controller="Game" asp-action="CompleteGateMission" method="post"><input type="hidden" name="gateMissionId" value="@m.Id" /><button type="submit" disabled="@(Model.NowUtc < m.CompletesAtUtc)">Bericht abrufen</button></form></td></tr>}</tbody></table>}</section>
<section class="panel"><h2>Teamübersicht</h2><table><thead><tr><th>Team</th><th>Stärke</th><th>Wissenschaft</th><th>Diplomatie</th><th>Tarnung</th><th>Traglast</th><th>Risiko</th><th>Status</th></tr></thead><tbody>@foreach(var t in Model.MissionTeams){<tr><td>@t.Name</td><td>@t.Strength</td><td>@t.Science</td><td>@t.Diplomacy</td><td>@t.Stealth</td><td>@t.CarryCapacity</td><td>@t.Risk</td><td>@(t.IsAvailable ? "bereit" : "im Einsatz")</td></tr>}</tbody></table></section>
<section class="panel"><h2>Missionsergebnisse/Berichte</h2><table><thead><tr><th>Zeit</th><th>Ergebnis</th><th>Funde</th><th>Zusammenfassung</th></tr></thead><tbody>@foreach(var r in Model.GateMissionReports){<tr><td>@r.CreatedAtUtc.ToString("u")</td><td>@r.Outcome</td><td>NQ @r.NaquadahFound, TR @r.TriniumFound, VG @r.SuppliesFound, Intel @r.IntelFound, Artefaktspur @(r.ArtifactLeadFound ? "ja" : "nein")</td><td>@r.Summary</td></tr>}</tbody></table></section>
