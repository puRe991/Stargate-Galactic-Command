@model StargateGalacticCommand.Web.Models.OverviewViewModel
@{ ViewData["Title"] = "Kampfberichte"; }
<h1>Kampfberichte</h1>
@if (TempData["Error"] != null) { <div class="alert">@TempData["Error"]</div> }
@if (TempData["Message"] != null) { <div class="success">@TempData["Message"]</div> }
<section><h2>Schutzstatus</h2>@if (Model.ProtectionStatus == null) { <p>Kein aktiver Basisschutz.</p> } else { <p>Geschützt bis @Model.ProtectionStatus.ProtectedUntilUtc.ToString("u"), Score @Model.ProtectionStatus.Score</p> }</section>
<section><h2>Aktive Angriffe</h2>@foreach (var m in Model.ActiveSpaceCombats) { <form method="post" asp-action="CompleteSpaceCombat"><input type="hidden" name="missionId" value="@m.Id" />@m.TargetBase.Name – Ankunft @m.ArrivesAtUtc.ToString("u") <button type="submit">Berechnen</button></form> }</section>
<section><h2>Berichte</h2>@foreach (var r in Model.SpaceCombatReports) { <article><h3>@r.Title</h3><p>@r.Body</p></article> }</section>
<section><h2>Trümmerfelder</h2><table><tr><th>Basis</th><th>Naquadah</th><th>Trinium</th></tr>@foreach (var d in Model.DebrisFields) { <tr><td>@d.PlayerBase.Name (@d.PlayerBase.PlanetSector.Planet.Name Sektor @d.PlayerBase.PlanetSector.Number)</td><td>@d.Naquadah</td><td>@d.Trinium</td></tr> }</table><p>Bergungsflotten können auf der Seite „Flotte senden“ zu einem Trümmerfeld geschickt werden.</p></section>
