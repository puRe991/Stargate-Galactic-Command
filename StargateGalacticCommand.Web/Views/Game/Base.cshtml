@model OverviewViewModel
@{ ViewData["Title"] = "Basis"; }
@using StargateGalacticCommand.Core.Models
@functions {
    string Cost(BuildCost c) => $"NQ {c.Naquadah}, TR {c.Trinium}, VG {c.Supplies}" + (c.Intel > 0 ? $", Intel {c.Intel}" : "");
    string Duration(int seconds) => TimeSpan.FromSeconds(seconds).ToString(@"hh\:mm\:ss");
}
@if (TempData["Message"] != null) { <div class="notice success">@TempData["Message"]</div> }
@if (TempData["Error"] != null) { <div class="notice error">@TempData["Error"]</div> }
<section class="panel"><h1>@ViewData["Title"]</h1><table><tr><th>Spieler</th><td>@Model.User.UserName</td></tr><tr><th>Fraktion</th><td>@Model.User.Faction.Name</td></tr><tr><th>Basis</th><td>@Model.Base.Name</td></tr><tr><th>Planet</th><td>@Model.Planet.Name (@Model.Planet.Galaxy, @Model.Planet.Type, Stargate @(Model.Planet.StargateActive ? "aktiv" : "inaktiv"), @Model.Planet.Status)</td></tr><tr><th>Sektor</th><td>@Model.Base.PlanetSector.Number - @Model.Base.PlanetSector.Name</td></tr></table></section>
<section class="panel"><h2>Ressourcen</h2><table><thead><tr><th>Ressource</th><th>Bestand</th><th>Produktion/Stunde</th></tr></thead><tbody><tr><td>Naquadah</td><td>@Model.Base.Resources.Naquadah</td><td>@Model.Hourly.Naquadah</td></tr><tr><td>Trinium</td><td>@Model.Base.Resources.Trinium</td><td>@Model.Hourly.Trinium</td></tr><tr><td>Versorgungsgüter</td><td>@Model.Base.Resources.Supplies</td><td>@Model.Hourly.Supplies</td></tr><tr><td>Energie</td><td>@Model.Base.Resources.Energy</td><td>@Model.Hourly.Energy</td></tr><tr><td>Personal</td><td>@Model.Base.Resources.Personnel</td><td>@Model.Hourly.Personnel</td></tr><tr><td>Intel</td><td>@Model.Base.Resources.Intel</td><td>@Model.Hourly.Intel</td></tr></tbody></table></section>
<section class="panel"><h2>Bauwarteschlange</h2>@if (Model.ActiveBuild == null) { <p>Keine aktiven Bauaufträge.</p> } else { var left = Model.ActiveBuild.CompletesAtUtc - Model.NowUtc; if (left < TimeSpan.Zero) { left = TimeSpan.Zero; } <table><tr><th>Gebäude</th><td>@Model.Buildings.Single(b => b.Type == Model.ActiveBuild.BuildingType).Name</td></tr><tr><th>Ziellevel</th><td>@Model.ActiveBuild.TargetLevel</td></tr><tr><th>Fertigstellung</th><td>@Model.ActiveBuild.CompletesAtUtc.ToString("u")</td></tr><tr><th>Restzeit</th><td><span class="build-timer" data-completes="@Model.ActiveBuild.CompletesAtUtc.ToString("O")">@left.ToString(@"hh\:mm\:ss")</span></td></tr></table> }</section>
<section class="panel"><h2>Gebäude</h2><table><thead><tr><th>Gebäude</th><th>Level</th><th>Kosten</th><th>Bauzeit</th><th>Aktion</th></tr></thead><tbody>@foreach(var b in Model.Buildings){<tr><td>@b.Name</td><td>@b.Level</td><td>@Cost(b.Cost)</td><td>@Duration(b.BuildSeconds)</td><td><form asp-controller="Game" asp-action="StartBuild" method="post"><input type="hidden" name="buildingType" value="@b.Type" /><button type="submit" disabled="@(b.QueueBusy || !b.CanAfford)">Ausbauen</button>@if (b.QueueBusy) { <span class="hint"> Bauplatz belegt</span> } else if (!b.CanAfford) { <span class="hint"> Zu wenig Ressourcen</span> }</form></td></tr>}</tbody></table></section>
<section class="panel"><h2>Sektoren</h2><table><thead><tr><th>#</th><th>Name</th><th>Typ</th><th>Status</th></tr></thead><tbody>@foreach(var s in Model.Sectors){<tr><td>@s.Number</td><td>@s.Name</td><td>@(s.IsSettlementSector ? "Siedlung" : "Spezialsektor")</td><td>@(s.PlayerBase == null ? "frei" : "belegt")</td></tr>}</tbody></table></section>
<section class="panel"><h2>Berichte</h2><table><thead><tr><th>Zeit</th><th>Titel</th><th>Text</th></tr></thead><tbody>@foreach(var r in Model.Reports){<tr><td>@r.CreatedAtUtc.ToString("u")</td><td>@r.Title</td><td>@r.Body</td></tr>}</tbody></table></section>
<script>document.querySelectorAll('.build-timer').forEach(function(e){function tick(){var ms=new Date(e.dataset.completes)-new Date();if(ms<0)ms=0;var s=Math.floor(ms/1000),h=Math.floor(s/3600);s%=3600;var m=Math.floor(s/60);s%=60;e.textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');}tick();setInterval(tick,1000);});</script>
