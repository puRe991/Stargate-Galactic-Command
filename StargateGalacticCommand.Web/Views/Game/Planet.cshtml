@model OverviewViewModel
@using StargateGalacticCommand.Core.Services
@{
    ViewData["Title"] = "Planet";
    string DecayStatus(PlanetSector s)
    {
        if (s.SectorControl == null) return "";
        double hoursSinceReinforced = (Model.NowUtc - s.SectorControl.LastReinforcedAtUtc).TotalHours;
        if (hoursSinceReinforced <= LocalSectorService.DecayGracePeriodHours) return "Präsenz aktiv";
        double hoursLeft = LocalSectorService.DecayReleaseAfterHours - hoursSinceReinforced;
        return hoursLeft > 0 ? "Einfluss verfällt, Freigabe in " + Math.Ceiling(hoursLeft) + " h" : "wird freigegeben";
    }
}

<section class="panel">
    <h1>@Model.Planet.Name</h1>
    <p>Gemeinsamer Planet: Spieler kontrollieren Basen und gesicherte Sektoren, nicht den ganzen Planeten. Version 0.0.9 erlaubt kontrollierte lokale Konflikte um neutrale oder umkämpfte Ressourcenzonen; Hauptbasen bleiben geschützt.</p>
    <table>
        <tr>
            <th>Eigener Einfluss</th>
            <td>@Model.OwnInfluence</td>
        </tr>
        <tr>
            <th>Aktive lokale Boni</th>
            <td>Naquadah +@(Model.SectorBonus.NaquadahMultiplier * 100) %, Trinium +@(Model.SectorBonus.TriniumMultiplier * 100) %, Versorgung +@(Model.SectorBonus.SuppliesMultiplier * 100) %, Personal +@(Model.SectorBonus.PersonnelMultiplier * 100) %, Intel +@(Model.SectorBonus.IntelMultiplier * 100) %</td>
        </tr>
    </table>
</section>

<section class="panel">
    <h2>Sektoren</h2>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Typ</th>
                <th>Status</th>
                <th>Präsenz</th>
                <th>Risiko</th>
                <th>Aktion</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Sectors)
            {
                var claim = Model.ActiveSectorClaims.FirstOrDefault(c => c.PlanetSectorId == s.Id);
                <tr>
                    <td>@s.Number</td>
                    <td>@s.Name</td>
                    <td>@s.SectorType</td>
                    <td>
                        @if (s.PlayerBase != null)
                        {
                            <text>Basis</text>
                        }
                        else if (s.SectorControl != null)
                        {
                            <text>kontrolliert</text>
                        }
                        else if (claim != null)
                        {
                            <text>Beanspruchung läuft bis @claim.CompletesAtUtc.ToString("u") <span class="cooldown-timer" data-completes="@claim.CompletesAtUtc.ToString("O")" data-ready-text="fertig"></span></text>
                        }
                        else
                        {
                            <text>neutral</text>
                        }
                    </td>
                    <td>@DecayStatus(s)</td>
                    <td>@(s.PlayerBase != null || s.SectorType == SectorType.StargateZone || s.SectorType == SectorType.SettlementSector ? "geschützt" : s.SectorControl == null ? "niedrig" : "mittel")</td>
                    <td>
                        @if (s.PlayerBase == null && s.SectorControl == null && claim == null && s.SectorType != SectorType.SettlementSector && s.SectorType != SectorType.StargateZone)
                        {
                            <form asp-action="ClaimSector" method="post">
                                <input type="hidden" name="sectorId" value="@s.Id" />
                                <button type="submit">Sichern</button>
                            </form>
                        }
                        else if (claim != null && claim.UserId == Model.User.Id)
                        {
                            <form asp-action="CompleteSectorClaim" method="post">
                                <input type="hidden" name="claimId" value="@claim.Id" />
                                <button id="claim-@claim.Id" type="submit" disabled="@(claim.CompletesAtUtc > Model.NowUtc)">Abschließen</button>
                            </form>
                            @if (claim.CompletesAtUtc > Model.NowUtc)
                            {
                                <span class="cooldown-timer" data-completes="@claim.CompletesAtUtc.ToString("O")" data-enable-selector="#claim-@claim.Id" data-ready-text="bereit"></span>
                            }
                        }
                        else if (s.SectorControl != null && s.SectorControl.UserId == Model.User.Id)
                        {
                            <form asp-action="ReinforceSector" method="post">
                                <input type="hidden" name="sectorId" value="@s.Id" />
                                <button type="submit">Präsenz bestätigen</button>
                            </form>
                        }
                        else if (s.PlayerBase == null && s.SectorType != SectorType.SettlementSector && s.SectorType != SectorType.StargateZone && (s.SectorControl == null || s.SectorControl.UserId != Model.User.Id))
                        {
                            var lastAttack = Model.SectorBattleReports.Where(r => r.PlanetSectorId == s.Id).OrderByDescending(r => r.CreatedAtUtc).FirstOrDefault();
                            DateTime? cooldownEndsUtc = lastAttack == null ? (DateTime?)null : lastAttack.CreatedAtUtc.AddHours(LocalCombatService.SectorAttackCooldownHours);
                            bool onCooldown = cooldownEndsUtc.HasValue && cooldownEndsUtc.Value > Model.NowUtc;
                            <form asp-action="StartLocalCombat" method="post">
                                <input type="hidden" name="sectorId" value="@s.Id" />
                                <select name="objective">
                                    <option value="SecureNeutralResourceZone">Neutrale Ressourcenzone sichern</option>
                                    <option value="CaptureContestedResourceZone">Umkämpfte Ressourcenzone übernehmen</option>
                                    <option value="DisruptOutpost">Außenposten stören</option>
                                    <option value="SecureRuinAccess">Ruinenzugang sichern</option>
                                </select>
                                <input type="number" name="sgSecurityTeams" min="0" value="1" title="SG-Sicherheitsteam" />
                                <input type="number" name="marines" min="0" value="0" title="Marines" />
                                <input type="number" name="jaffaWarriors" min="0" value="0" title="Jaffa-Krieger" />
                                <input type="number" name="eliteJaffa" min="0" value="0" title="Elite-Jaffa" />
                                <input type="number" name="agentCells" min="0" value="0" title="Agentenzelle" />
                                <input type="number" name="saboteurs" min="0" value="0" title="Saboteur" />
                                <input type="number" name="mercenaries" min="0" value="0" title="Söldner" />
                                <input type="number" name="smugglerSquads" min="0" value="0" title="Schmugglertrupp" />
                                <button id="attack-@s.Id" type="submit" disabled="@onCooldown">Angreifen</button>
                            </form>
                            @if (onCooldown)
                            {
                                <span class="cooldown-timer" data-completes="@cooldownEndsUtc.Value.ToString("O")" data-enable-selector="#attack-@s.Id" data-ready-text="bereit"></span>
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="panel">
    <h2>Kontrollierte Sektoren</h2>
    <ul>
        @foreach (var s in Model.ControlledSectors)
        {
            <li>@s.Number - @s.Name (@s.SectorType)</li>
        }
    </ul>
</section>

<section class="panel">
    <h2>Einflussrangliste</h2>
    <table>
        <thead>
            <tr>
                <th>Rang</th>
                <th>Spieler</th>
                <th>Einfluss</th>
            </tr>
        </thead>
        <tbody>
            @{
                var rank = 1;
            }
            @foreach (var influence in Model.PlanetInfluences)
            {
                <tr>
                    <td>@rank</td>
                    <td>@influence.UserName</td>
                    <td>@influence.Score</td>
                </tr>
                rank++;
            }
        </tbody>
    </table>
</section>

<section class="panel">
    <h2>Laufende lokale Konflikte</h2>
    <table><thead><tr><th>Sektor</th><th>Ziel</th><th>Ankunft</th><th>Aktion</th></tr></thead><tbody>
    @foreach (var c in Model.ActiveLocalCombats)
    {
        <tr>
            <td>@c.PlanetSector.Number - @c.PlanetSector.Name</td>
            <td>@c.Objective</td>
            <td>@c.ResolvesAtUtc.ToString("u") <span class="mission-timer" data-completes="@c.ResolvesAtUtc.ToString("O")" data-ready-text="angekommen"></span></td>
            <td>
                @if (c.AttackerUserId == Model.User.Id)
                {
                    <form asp-action="CompleteLocalCombat" method="post">
                        <input type="hidden" name="missionId" value="@c.Id" />
                        <button id="combat-@c.Id" type="submit" disabled="@(c.ResolvesAtUtc > Model.NowUtc)">Kampf berechnen</button>
                    </form>
                    @if (c.ResolvesAtUtc > Model.NowUtc)
                    {
                        <span class="cooldown-timer" data-completes="@c.ResolvesAtUtc.ToString("O")" data-enable-selector="#combat-@c.Id" data-ready-text="bereit"></span>
                    }
                }
                else
                {
                    <span>läuft</span>
                }
            </td>
        </tr>
    }
    </tbody></table>
</section>

<section class="panel">
    <h2>Kampfberichte</h2>
    @foreach (var r in Model.SectorBattleReports)
    {
        <article><h3>@r.Title - @r.PlanetSector.Name</h3><pre>@r.Body</pre></article>
    }
</section>
