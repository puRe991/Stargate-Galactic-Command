@model StargateGalacticCommand.Web.Models.OverviewViewModel
@using StargateGalacticCommand.Core.Models
@using StargateGalacticCommand.Core.Services
@{ ViewData["Title"] = "Allianzen"; }
<h1>Allianzen</h1>
@if (TempData["Error"] != null) { <div class="alert">@TempData["Error"]</div> }
@if (TempData["Message"] != null) { <div class="success">@TempData["Message"]</div> }
@if (Model.OwnAlliance == null)
{
    <section><h2>Allianz erstellen</h2><form method="post" asp-action="CreateAlliance"><input name="name" placeholder="Name" maxlength="80" required /><input name="tag" placeholder="Tag" maxlength="8" required /><textarea name="description" placeholder="Beschreibung"></textarea><button type="submit">Erstellen</button></form></section>
}
else
{
    var ownMembership = Model.OwnAlliance.Members.SingleOrDefault(m => m.UserId == Model.User.Id);
    <section><h2>[@Model.OwnAlliance.Tag] @Model.OwnAlliance.Name</h2><p>@Model.OwnAlliance.Description</p><h3>Mitglieder</h3><ul>@foreach (var m in Model.OwnAlliance.Members.OrderBy(m => m.Rank)) { <li>@m.User.UserName – @m.Rank@(m.MentorUserId.HasValue ? " (Mentor: " + Model.OwnAlliance.Members.SingleOrDefault(x => x.UserId == m.MentorUserId)?.User.UserName + ")" : "")</li> }</ul></section>
    <section>
        <h2>Mentoren-System</h2>
        <p>Erfahrene Allianzmitglieder können neuen Mitgliedern als Mentor zur Seite stehen. Wählt der Neuling innerhalb der ersten @StargateGalacticCommand.Core.Services.MentorService.MentorshipWindowDays Tage nach Beitritt einen Mentor, erhält dieser eine Belohnung, sobald der Schützling seine erste Gate-Mission abschließt bzw. seinen ersten Sektor kontrolliert.</p>
        @if (ownMembership != null)
        {
            @if (ownMembership.MentorUserId.HasValue)
            {
                <p>Dein Mentor: @Model.OwnAlliance.Members.SingleOrDefault(x => x.UserId == ownMembership.MentorUserId)?.User.UserName</p>
            }
            else if (Model.NowUtc <= ownMembership.JoinedAtUtc.AddDays(StargateGalacticCommand.Core.Services.MentorService.MentorshipWindowDays))
            {
                <form method="post" asp-action="AssignMentor">
                    <label>Mentor wählen</label>
                    <select name="mentorUserId">@foreach (var m in Model.OwnAlliance.Members.Where(m => m.UserId != Model.User.Id)) { <option value="@m.UserId">@m.User.UserName</option> }</select>
                    <button type="submit">Mentor wählen</button>
                </form>
            }
            else
            {
                <p>Zeitfenster für die Mentorenwahl ist abgelaufen.</p>
            }
        }
    </section>
}
<section><h2>Allianzsuche</h2><table><tr><th>Tag</th><th>Name</th><th>Mitglieder</th><th></th></tr>@foreach (var a in Model.Alliances) { <tr><td>@a.Tag</td><td>@a.Name</td><td>@a.Members.Count</td><td>@if (Model.OwnAlliance == null) { <form method="post" asp-action="ApplyAlliance"><input type="hidden" name="allianceId" value="@a.Id" /><input name="message" placeholder="Nachricht" /><button type="submit">Bewerben</button></form> }</td></tr> }</table></section>
@if (Model.OwnAlliance != null)
{
<section><h2>Offene Bewerbungen</h2>@foreach (var app in Model.AllianceApplications.Where(a => a.AllianceId == Model.OwnAlliance.Id)) { <form method="post" asp-action="AcceptAllianceApplication"><input type="hidden" name="applicationId" value="@app.Id" />@app.User.UserName: @app.Message <button type="submit">Annehmen</button></form> }</section>
<section>
    <h2>Kriegsziel</h2>
    <p>Hält die Allianz gemeinsam genug Sektoren auf einem Planeten durchgehend, schaltet sich ein einmaliger Ressourcenbonus für alle Mitglieder frei.</p>
    @if (Model.ActiveWarGoal == null)
    {
        <p>Kein aktives Kriegsziel.</p>
        @if (Model.CanManageWarGoal)
        {
            <form method="post" asp-action="DeclareWarGoal">
                <label>Zielplanet</label>
                <select name="planetId">@foreach (var p in Model.WarGoalPlanetOptions) { <option value="@p.Id">@p.Name</option> }</select>
                <button type="submit">Kriegsziel erklären</button>
            </form>
        }
    }
    else
    {
        <p>
            Ziel: @Model.ActiveWarGoal.Planet.Name –
            @Model.WarGoalCurrentSectors / @Model.ActiveWarGoal.RequiredSectors Sektoren kontrolliert,
            @(Model.ActiveWarGoal.RequiredHours)h durchgehend nötig
            @(Model.ActiveWarGoal.HoldStreakStartedAtUtc.HasValue ? " (Serie läuft seit " + Model.ActiveWarGoal.HoldStreakStartedAtUtc.Value.ToString("u") + ")" : " (Zielwert aktuell nicht erreicht)")
        </p>
        @if (Model.CanManageWarGoal)
        {
            <form method="post" asp-action="AbandonWarGoal">
                <input type="hidden" name="warGoalId" value="@Model.ActiveWarGoal.Id" />
                <button type="submit">Kriegsziel aufgeben</button>
            </form>
        }
    }
</section>
<section>
    <h2>Diplomatie</h2>
    <p>Nichtangriffspakte verhindern gegenseitige Weltraumangriffe und reduzieren die Markt-Gebühr bei Handel zwischen den beiden Allianzen um @((StargateGalacticCommand.Core.Services.DiplomacyService.PactMarketFeeReduction).ToString("P0")). Ein gebrochener Pakt sperrt die brechende Allianz für @StargateGalacticCommand.Core.Services.DiplomacyService.PactBreakCooldownDays Tage von einem neuen Vorschlag an dieselbe Allianz.</p>
    @if (!Model.DiplomacyStatuses.Any())
    {
        <p>Keine diplomatischen Beziehungen.</p>
    }
    else
    {
        <table><thead><tr><th>Allianz</th><th>Status</th><th>Seit</th><th>Aktion</th></tr></thead><tbody>
        @foreach (var d in Model.DiplomacyStatuses)
        {
            var other = d.AllianceAId == Model.OwnAlliance.Id ? d.AllianceB : d.AllianceA;
            <tr>
                <td>[@other.Tag] @other.Name</td>
                <td>@(d.Status == AllianceDiplomacyStatusType.Proposed ? "Vorschlag" : d.Status == AllianceDiplomacyStatusType.Pact ? "Pakt" : "Krieg")</td>
                <td>
                    @d.SinceUtc.ToString("u")
                    @if (d.Status == AllianceDiplomacyStatusType.War && d.BrokenByAllianceId == Model.OwnAlliance.Id && d.LastBrokenAtUtc.HasValue)
                    {
                        var cooldownEndsUtc = d.LastBrokenAtUtc.Value.AddDays(DiplomacyService.PactBreakCooldownDays);
                        if (cooldownEndsUtc > Model.NowUtc)
                        {
                            <br /><small class="hint">Paktvorschlag wieder möglich in <span class="cooldown-timer" data-completes="@cooldownEndsUtc.ToString("O")" data-ready-text="jetzt"></span></small>
                        }
                    }
                </td>
                <td>
                    @if (Model.CanManageWarGoal && d.Status == AllianceDiplomacyStatusType.Proposed && d.ProposedByAllianceId != Model.OwnAlliance.Id)
                    {
                        <form method="post" asp-action="AcceptPact" style="display:inline"><input type="hidden" name="diplomacyStatusId" value="@d.Id" /><button type="submit">Pakt annehmen</button></form>
                    }
                    @if (Model.CanManageWarGoal && d.Status != AllianceDiplomacyStatusType.War)
                    {
                        <form method="post" asp-action="DeclareAllianceWar" style="display:inline"><input type="hidden" name="targetAllianceId" value="@other.Id" /><button type="submit">Krieg erklären</button></form>
                    }
                </td>
            </tr>
        }
        </tbody></table>
    }
    @if (Model.CanManageWarGoal)
    {
        <form method="post" asp-action="ProposePact">
            <label>Allianz für Paktvorschlag</label>
            <select name="targetAllianceId">@foreach (var a in Model.Alliances.Where(a => a.Id != Model.OwnAlliance.Id)) { <option value="@a.Id">[@a.Tag] @a.Name</option> }</select>
            <button type="submit">Pakt vorschlagen</button>
        </form>
    }
</section>
}
