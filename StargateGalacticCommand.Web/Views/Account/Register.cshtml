@model RegisterViewModel
@{
    ViewData["Title"]="Registrierung";
    string FactionIcon(string shortName) => shortName switch
    {
        "SGC" => "sgc",
        "Jaffa" => "jaffa",
        "Tok’ra" => "tokra",
        "Lucian" => "lucian",
        _ => "sgc"
    };
}
<section class="panel">
    <h1>Registrierung</h1>
    <p>Server: <strong>@Model.ServerName</strong> · <a asp-controller="Server" asp-action="Select">anderen Server wählen</a></p>
    @if(!string.IsNullOrEmpty(Model.Error)){<p class="error">@Model.Error</p>}
    <form method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="error"></div>
        <label>Benutzername<input asp-for="UserName" /></label>
        <span asp-validation-for="UserName" class="error"></span>
        <label>E-Mail<input asp-for="Email" /></label>
        <span asp-validation-for="Email" class="error"></span>
        <label>Passwort<input asp-for="Password" type="password" /></label>
        <span asp-validation-for="Password" class="error"></span>
        <fieldset class="faction-picker">
            <legend>Fraktion</legend>
            <div class="faction-grid">
                @foreach (var f in Model.Factions)
                {
                    <label class="faction-card">
                        <input type="radio" name="FactionId" value="@f.Id" required />
                        <img src="~/images/factions/@(FactionIcon(f.ShortName)).svg" alt="" width="40" height="40" />
                        <span>@f.Name</span>
                    </label>
                }
            </div>
        </fieldset>
        <span asp-validation-for="FactionId" class="error"></span>
        <button type="submit">Basis gründen</button>
    </form>
    <p>Bereits ein Konto? <a asp-controller="Account" asp-action="Login">Jetzt einloggen</a></p>
</section>
