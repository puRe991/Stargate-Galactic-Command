@model LoginViewModel
@{ ViewData["Title"]="Login"; }
<section class="panel">
    <h1>Login</h1>
    <p>Server: <strong>@Model.ServerName</strong> · <a asp-controller="Server" asp-action="Select">anderen Server wählen</a></p>
    @if(!string.IsNullOrEmpty(Model.Error)){<p class="error">@Model.Error</p>}
    <form method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="error"></div>
        <label>Benutzername oder E-Mail<input asp-for="UserNameOrEmail" /></label>
        <span asp-validation-for="UserNameOrEmail" class="error"></span>
        <label>Passwort<input asp-for="Password" type="password" /></label>
        <span asp-validation-for="Password" class="error"></span>
        <button type="submit">Einloggen</button>
    </form>
    <p>Noch kein Konto? <a asp-controller="Account" asp-action="Register">Jetzt registrieren</a></p>
</section>
