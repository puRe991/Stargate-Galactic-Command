@using StargateGalacticCommand.Web.Models
@using Microsoft.AspNetCore.Http
@{
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);
    var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty);
    var isAuthenticated = Context.Session.GetInt32("UserId").HasValue;
    var gameModel = Model as OverviewViewModel;
    var commanderName = gameModel?.User?.UserName ?? "Commander";

    string Active(string targetController, string targetAction)
    {
        return string.Equals(controller, targetController, StringComparison.OrdinalIgnoreCase)
            && string.Equals(action, targetAction, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : string.Empty;
    }

    string GroupOpen(params string[] actions)
    {
        return actions.Any(a => string.Equals(action, a, StringComparison.OrdinalIgnoreCase)) ? "open" : string.Empty;
    }
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Stargate Galactic Command</title>
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <div class="container command-header">
            <a class="brand" asp-controller="Home" asp-action="Index" aria-label="Stargate Galactic Command Startseite">
                <span class="brand-mark"><img src="~/images/stargate-emblem.svg" alt="" width="48" height="48" /></span>
                <span><strong>Stargate Galactic Command</strong><small>Version 0.1.0 · Deep Space Operations</small></span>
            </a>

            <nav class="command-nav" aria-label="Hauptnavigation">
                <details class="nav-shell" open>
                    <summary>Navigation</summary>
                    <div class="nav-content">
                        @if (isAuthenticated)
                        {
                            <a class="nav-link @(Active("Game", "Overview"))" asp-controller="Game" asp-action="Overview">Übersicht</a>
                            <a class="nav-link @(Active("Game", "Contracts"))" asp-controller="Game" asp-action="Contracts">Kontrakte</a>
                            <a class="nav-link @(Active("Game", "Codex"))" asp-controller="Game" asp-action="Codex">Kodex</a>
                            <a class="nav-link @(Active("Game", "Questlines"))" asp-controller="Game" asp-action="Questlines">Questline</a>
                            <div class="nav-group @(GroupOpen("Base", "Planet", "Resources", "SpecialResources", "Research", "GateRoom", "Sectors"))">
                                <span class="nav-group-title">Basis-Verwaltung</span>
                                <a class="nav-link @(Active("Game", "Base"))" asp-controller="Game" asp-action="Base">Basis</a>
                                <a class="nav-link @(Active("Game", "Planet"))" asp-controller="Game" asp-action="Planet">Planet</a>
                                <a class="nav-link @(Active("Game", "Resources"))" asp-controller="Game" asp-action="Resources">Ressourcen</a>
                                <a class="nav-link @(Active("Game", "SpecialResources"))" asp-controller="Game" asp-action="SpecialResources">Spezialressourcen</a>
                                <a class="nav-link @(Active("Game", "Research"))" asp-controller="Game" asp-action="Research">Forschung</a>
                                <a class="nav-link @(Active("Game", "GateRoom"))" asp-controller="Game" asp-action="GateRoom">Gate-Raum</a>
                                <a class="nav-link @(Active("Game", "Sectors"))" asp-controller="Game" asp-action="Sectors">Sektoren</a>
                            </div>
                            <div class="nav-group @(GroupOpen("Shipyard", "Ships", "SendFleet", "Fleets", "Orbit"))">
                                <span class="nav-group-title">Militär</span>
                                <a class="nav-link @(Active("Game", "Shipyard"))" asp-controller="Game" asp-action="Shipyard">Werft</a>
                                <a class="nav-link @(Active("Game", "Ships"))" asp-controller="Game" asp-action="Ships">Schiffe</a>
                                <a class="nav-link @(Active("Game", "SendFleet"))" asp-controller="Game" asp-action="SendFleet">Flotte senden</a>
                                <a class="nav-link @(Active("Game", "Fleets"))" asp-controller="Game" asp-action="Fleets">Flotten</a>
                                <a class="nav-link @(Active("Game", "Orbit"))" asp-controller="Game" asp-action="Orbit">Orbit</a>
                            </div>
                            <div class="nav-group @(GroupOpen("Market", "Alliances", "Intelligence"))">
                                <span class="nav-group-title">Diplomatie & Intel</span>
                                <a class="nav-link @(Active("Game", "Market"))" asp-controller="Game" asp-action="Market">Markt</a>
                                <a class="nav-link @(Active("Game", "Alliances"))" asp-controller="Game" asp-action="Alliances">Allianzen</a>
                                <a class="nav-link @(Active("Game", "Intelligence"))" asp-controller="Game" asp-action="Intelligence">Geheimdienst</a>
                            </div>
                            <div class="nav-group @(GroupOpen("Reports", "CombatReports", "FleetReports"))">
                                <span class="nav-group-title">Berichte</span>
                                <a class="nav-link @(Active("Game", "Reports"))" asp-controller="Game" asp-action="Reports">Berichte @if (gameModel != null && gameModel.UnreadReportCount > 0) { <span class="nav-badge">@gameModel.UnreadReportCount</span> }</a>
                                <a class="nav-link @(Active("Game", "CombatReports"))" asp-controller="Game" asp-action="CombatReports">Kampfberichte</a>
                                <a class="nav-link @(Active("Game", "FleetReports"))" asp-controller="Game" asp-action="FleetReports">Flottenberichte</a>
                            </div>
                            <div class="nav-group @(GroupOpen("Rankings", "Galaxy", "Mailbox"))">
                                <span class="nav-group-title">Gemeinschaft</span>
                                <a class="nav-link @(Active("Game", "Rankings"))" asp-controller="Game" asp-action="Rankings">Rangliste</a>
                                <a class="nav-link @(Active("Game", "Galaxy"))" asp-controller="Game" asp-action="Galaxy">Galaxie</a>
                                <a class="nav-link @(Active("Game", "Mailbox"))" asp-controller="Game" asp-action="Mailbox">Postfach @if (gameModel != null && gameModel.UnreadMessageCount > 0) { <span class="nav-badge">@gameModel.UnreadMessageCount</span> }</a>
                            </div>
                            <div class="nav-account"><span>@commanderName</span><a class="nav-link" asp-controller="Account" asp-action="Logout">Logout</a></div>
                        }
                        else
                        {
                            <a class="nav-link @(Active("Home", "Index"))" asp-controller="Home" asp-action="Index">Start</a>
                            <a class="nav-link @(Active("Server", "Select"))" asp-controller="Server" asp-action="Select">Server auswählen</a>
                        }
                    </div>
                </details>
            </nav>
        </div>
        @if (isAuthenticated && gameModel?.Base?.Resources != null)
        {
            <div class="resource-strip" aria-label="Ressourcenübersicht">
                <div class="container resource-grid">
                    <div class="res-cell"><img class="res-icon" src="~/images/resources/naquadah.svg" alt="" width="18" height="18" /><span><b>Naquadah</b>@gameModel.Base.Resources.Naquadah</span></div>
                    <div class="res-cell"><img class="res-icon" src="~/images/resources/trinium.svg" alt="" width="18" height="18" /><span><b>Trinium</b>@gameModel.Base.Resources.Trinium</span></div>
                    <div class="res-cell"><img class="res-icon" src="~/images/resources/supplies.svg" alt="" width="18" height="18" /><span><b>Supplies</b>@gameModel.Base.Resources.Supplies</span></div>
                    <div class="res-cell"><img class="res-icon" src="~/images/resources/energy.svg" alt="" width="18" height="18" /><span><b>Energy</b>@gameModel.Base.Resources.Energy</span></div>
                    <div class="res-cell"><img class="res-icon" src="~/images/resources/personnel.svg" alt="" width="18" height="18" /><span><b>Personnel</b>@gameModel.Base.Resources.Personnel</span></div>
                    <div class="res-cell"><img class="res-icon" src="~/images/resources/intel.svg" alt="" width="18" height="18" /><span><b>Intel</b>@gameModel.Base.Resources.Intel</span></div>
                </div>
            </div>
        }
    </header>
    <main class="container command-main">@RenderBody()</main>
    <script src="~/js/command-countdowns.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
