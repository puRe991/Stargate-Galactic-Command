@model AdminLoginViewModel
@{ ViewData["Title"] = "Admin-Login"; Layout = null; }
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <title>Admin-Login - Stargate Galactic Command</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <main class="container command-main">
        <section class="panel">
            <h1>Admin-Login</h1>
            @if (!string.IsNullOrEmpty(Model.Error)) { <p class="error">@Model.Error</p> }
            <form method="post">
                @Html.AntiForgeryToken()
                <label>Passwort<input asp-for="Password" type="password" /></label>
                <span asp-validation-for="Password" class="error"></span>
                <button type="submit">Einloggen</button>
            </form>
        </section>
    </main>
</body>
</html>
